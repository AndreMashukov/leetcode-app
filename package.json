{
  "name": "leetcode-app",
  "version": "0.1.0",
  "private": true,
  "description": "LeetCode App - AWS serverless coding platform. Fargate MVP sandbox for trusted/internal users. Six CF stacks on one EventBridge bus. Architecture based on 'System Design: Architecting a scalable coding platform like LeetCode'. Sibling to ../pastebin-app and ../url-shortener-app.",
  "license": "UNLICENSED",
  "workspaces": [
    "leetcode-event-hub",
    "leetcode-auth",
    "leetcode-problems-bff",
    "leetcode-submissions-bff",
    "leetcode-status-bff",
    "leetcode-worker-images",
    "leetcode-workers",
    "submission-playground",
    "libs/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "nx": "NX_SKIP_NATIVE_FILE_CACHE=true nx",
    "start": "NX_SKIP_NATIVE_FILE_CACHE=true nx run-many --target=serve",
    "build": "NX_SKIP_NATIVE_FILE_CACHE=true nx run-many --target=build",
    "test": "NX_SKIP_NATIVE_FILE_CACHE=true nx run-many --target=test",
    "typecheck": "NX_SKIP_NATIVE_FILE_CACHE=true nx run-many --target=typecheck",
    "package": "NX_SKIP_NATIVE_FILE_CACHE=true nx run-many --target=package",
    "deploy": "NX_SKIP_NATIVE_FILE_CACHE=true nx run-many --target=deploy",
    "info": "NX_SKIP_NATIVE_FILE_CACHE=true nx run-many --target=info",
    "show:projects": "NX_SKIP_NATIVE_FILE_CACHE=true nx show projects",
    "graph": "NX_SKIP_NATIVE_FILE_CACHE=true nx graph",
    "package:event-hub": "NX_SKIP_NATIVE_FILE_CACHE=true nx run leetcode-event-hub:package",
    "deploy:event-hub": "NX_SKIP_NATIVE_FILE_CACHE=true nx run leetcode-event-hub:deploy",
    "package:auth": "NX_SKIP_NATIVE_FILE_CACHE=true nx run leetcode-auth:package",
    "deploy:auth": "NX_SKIP_NATIVE_FILE_CACHE=true nx run leetcode-auth:deploy",
    "package:problems-bff": "NX_SKIP_NATIVE_FILE_CACHE=true nx run leetcode-problems-bff:package",
    "deploy:problems-bff": "NX_SKIP_NATIVE_FILE_CACHE=true nx run leetcode-problems-bff:deploy",
    "package:submissions-bff": "NX_SKIP_NATIVE_FILE_CACHE=true nx run leetcode-submissions-bff:package",
    "deploy:submissions-bff": "NX_SKIP_NATIVE_FILE_CACHE=true nx run leetcode-submissions-bff:deploy",
    "package:status-bff": "NX_SKIP_NATIVE_FILE_CACHE=true nx run leetcode-status-bff:package",
    "deploy:status-bff": "NX_SKIP_NATIVE_FILE_CACHE=true nx run leetcode-status-bff:deploy",
    "package:worker-images": "NX_SKIP_NATIVE_FILE_CACHE=true nx run leetcode-worker-images:package",
    "deploy:worker-images": "NX_SKIP_NATIVE_FILE_CACHE=true nx run leetcode-worker-images:deploy",
    "package:workers": "NX_SKIP_NATIVE_FILE_CACHE=true nx run leetcode-workers:package",
    "deploy:workers": "NX_SKIP_NATIVE_FILE_CACHE=true nx run leetcode-workers:deploy",
    "dev:playground": "NX_SKIP_NATIVE_FILE_CACHE=true nx run submission-playground:serve",
    "build:playground": "NX_SKIP_NATIVE_FILE_CACHE=true nx run submission-playground:build",
    "mint:jwt": "node scripts/mint-dev-jwt.mjs",
    "set:dev-user": "node scripts/set-dev-cognito-user.mjs",
    "seed:two-sum": "node scripts/seed-two-sum-problem.mjs"
  },
  "devDependencies": {
    "@nx/eslint": "22.6.5",
    "@nx/eslint-plugin": "22.6.5",
    "@nx/js": "22.6.5",
    "@nx/workspace": "22.6.5",
    "@types/node": "^20.0.0",
    "eslint": "^9.8.0",
    "jiti": "2.4.2",
    "nx": "22.6.5",
    "typescript": "~5.7.3"
  },
  "dependencies": {
    "@aws-sdk/client-cloudwatch-logs": "^3.1074.0",
    "@aws-sdk/client-cognito-identity-provider": "^3.1074.0"
  }
}
